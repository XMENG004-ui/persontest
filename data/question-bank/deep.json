  "questions": [
    {"id": "C01", "dimension": "control", "reverse": false, "text": "我习惯在事情开始前就规划好每一步。"},
    {"id": "C02", "dimension": "control", "reverse": false, "text": "当别人临时改变计划时，我会立刻介入重新安排。"},
    {"id": "C03", "dimension": "control", "reverse": true, "text": "在团队里我更喜欢随大流，而不是带头做决定。"},
    {"id": "C04", "dimension": "control", "reverse": false, "text": "如果情况失控，我会本能地寻找可控变量来收回局面。"},
    {"id": "C05", "dimension": "control", "reverse": true, "text": "只要别人处理得不错，我不一定要参与管理。"},
    {"id": "C06", "dimension": "control", "reverse": false, "text": "我会为最糟的情况准备备用方案。"},
    {"id": "C07", "dimension": "control", "reverse": false, "text": "我经常在脑海里模拟不同人可能的反应，提前准备应对。"},
    {"id": "C08", "dimension": "control", "reverse": false, "text": "只要我掌握关键节点，我就能放心把执行交给别人。"},
    {"id": "C09", "dimension": "control", "reverse": true, "text": "我享受在混乱中随遇而安，不需要掌控一切。"},
    {"id": "C10", "dimension": "control", "reverse": false, "text": "我倾向于把重要资源握在自己手里。"},
    {"id": "C11", "dimension": "control", "reverse": false, "text": "面对突发状况，我通常第一个站出来分配任务。"},
    {"id": "C12", "dimension": "control", "reverse": true, "text": "我不认为\"被动跟随\"会带来风险。"},
    {"id": "C13", "dimension": "control", "reverse": false, "text": "当别人质疑我的安排，我会用数据或逻辑压回去。"},
    {"id": "C14", "dimension": "control", "reverse": false, "text": "我会给自己制定行为守则以保持优势。"},
    {"id": "C15", "dimension": "control", "reverse": true, "text": "如果不是我负责的事情，我不会多管。"},
    {"id": "C16", "dimension": "control", "reverse": false, "text": "我喜欢把信息整理成自己的\"情报库\"。"},

    {"id": "E01", "dimension": "emotional", "reverse": false, "text": "我知道怎样用语气或沉默让别人顺着我。"},
    {"id": "E02", "dimension": "emotional", "reverse": false, "text": "我习惯观察对方的情绪再决定怎么说话。"},
    {"id": "E03", "dimension": "emotional", "reverse": true, "text": "在关系里我从不考虑利用信息优势。"},
    {"id": "E04", "dimension": "emotional", "reverse": false, "text": "我会根据对方的心理弱点来安排沟通节奏。"},
    {"id": "E05", "dimension": "emotional", "reverse": false, "text": "我愿意表现得更脆弱来换取我想要的回应。"},
    {"id": "E06", "dimension": "emotional", "reverse": true, "text": "我宁愿诚实表达，也不会用情绪去影响别人。"},
    {"id": "E07", "dimension": "emotional", "reverse": false, "text": "我会故意在关键时刻沉默来制造压力。"},
    {"id": "E08", "dimension": "emotional", "reverse": false, "text": "我善于让对方以为决策是他做的。"},
    {"id": "E09", "dimension": "emotional", "reverse": true, "text": "我表达情绪只为了真实传达，而不是影响结果。"},
    {"id": "E10", "dimension": "emotional", "reverse": false, "text": "我懂得在争执中点燃或熄灭对方的情绪。"},
    {"id": "E11", "dimension": "emotional", "reverse": false, "text": "我会记住别人的情绪\"按钮\"以备不时之需。"},
    {"id": "E12", "dimension": "emotional", "reverse": true, "text": "我从不利用对方向我倾诉的秘密。"},
    {"id": "E13", "dimension": "emotional", "reverse": false, "text": "当对方不配合时，我会换一种情绪姿态。"},
    {"id": "E14", "dimension": "emotional", "reverse": false, "text": "我懂得用节奏差（忽冷忽热）维持主动权。"},
    {"id": "E15", "dimension": "emotional", "reverse": false, "text": "我擅长用\"共情\"换取更多信息。"},
    {"id": "E16", "dimension": "emotional", "reverse": true, "text": "我觉得用情绪让别人让步是一种操控。"},

    {"id": "B01", "dimension": "benefit", "reverse": false, "text": "做决策时我会先算\"值不值\"。"},
    {"id": "B02", "dimension": "benefit", "reverse": false, "text": "如果一件事与收益无关，我很难投入。"},
    {"id": "B03", "dimension": "benefit", "reverse": true, "text": "即使没有明确好处，我也会凭感觉去做。"},
    {"id": "B04", "dimension": "benefit", "reverse": false, "text": "我擅长从对话里迅速判断对我有没有价值。"},
    {"id": "B05", "dimension": "benefit", "reverse": false, "text": "我常常把人际关系拆成\"成本\"和\"回报\"。"},
    {"id": "B06", "dimension": "benefit", "reverse": true, "text": "我不喜欢把人或事情量化成利益。"},
    {"id": "B07", "dimension": "benefit", "reverse": false, "text": "我常把人际互动拆成\"可交换项目\"。"},
    {"id": "B08", "dimension": "benefit", "reverse": false, "text": "如果资源有限，我会优先投资最可能回报的人。"},
    {"id": "B09", "dimension": "benefit", "reverse": true, "text": "我愿意为了纯粹的情感体验去冒经济风险。"},
    {"id": "B10", "dimension": "benefit", "reverse": false, "text": "我能迅速判断一段合作是否值得继续。"},
    {"id": "B11", "dimension": "benefit", "reverse": false, "text": "在冲突中我会先评估损益再决定态度。"},
    {"id": "B12", "dimension": "benefit", "reverse": true, "text": "与其算计，我更在乎真诚的连接。"},
    {"id": "B13", "dimension": "benefit", "reverse": false, "text": "我擅长用筹码和条件博弈。"},
    {"id": "B14", "dimension": "benefit", "reverse": false, "text": "当我帮助别人时，也会想好未来如何回收。"},
    {"id": "B15", "dimension": "benefit", "reverse": true, "text": "我不会为了掌控感而做过度布局。"},
    {"id": "B16", "dimension": "benefit", "reverse": false, "text": "我会维持多个备选方案防止自己被\"绑死\"。"},

    {"id": "D01", "dimension": "defense", "reverse": false, "text": "我懂得在冲突中抽离情绪，先保全自己。"},
    {"id": "D02", "dimension": "defense", "reverse": false, "text": "当别人情绪失控时，我更倾向保持冷静旁观。"},
    {"id": "D03", "dimension": "defense", "reverse": true, "text": "我通常会先安抚别人的情绪而不是保持距离。"},
    {"id": "D04", "dimension": "defense", "reverse": false, "text": "我可以很快把私人情绪\"关机\"切回理性模式。"},
    {"id": "D05", "dimension": "defense", "reverse": false, "text": "当我察觉风险时，会立即降低情感投入。"},
    {"id": "D06", "dimension": "defense", "reverse": true, "text": "我很难把感受和决策分开。"},
    {"id": "D07", "dimension": "defense", "reverse": false, "text": "我能把情绪和行动完全分开处理。"},
    {"id": "D08", "dimension": "defense", "reverse": false, "text": "当关系开始动荡，我会自觉降低自曝程度。"},
    {"id": "D09", "dimension": "defense", "reverse": true, "text": "我宁可先共情再讨论问题。"},
    {"id": "D10", "dimension": "defense", "reverse": false, "text": "面对控诉时，我通常只回应事实而不回应感受。"},
    {"id": "D11", "dimension": "defense", "reverse": false, "text": "我擅长把脆弱\"封存\"，只展示可控制的一面。"},
    {"id": "D12", "dimension": "defense", "reverse": true, "text": "我很难长时间保持距离，尤其在亲密关系里。"},
    {"id": "D13", "dimension": "defense", "reverse": false, "text": "我会用理性分析覆盖掉情绪波动。"},
    {"id": "D14", "dimension": "defense", "reverse": false, "text": "我可在几分钟内从激烈争吵切回冷静模式。"},
    {"id": "D15", "dimension": "defense", "reverse": false, "text": "越亲密的关系，我越会保留一份安全距离。"},
    {"id": "D16", "dimension": "defense", "reverse": true, "text": "我相信彻底敞开是建立信任的唯一方式。"},

    {"id": "P01", "dimension": "possessive", "reverse": false, "text": "一旦认定一段关系，我会建立自己的规则。"},
    {"id": "P02", "dimension": "possessive", "reverse": false, "text": "我会留意对方是否把注意力给了别人。"},
    {"id": "P03", "dimension": "possessive", "reverse": true, "text": "我觉得伴侣或朋友不需要跟我报备任何细节。"},
    {"id": "P04", "dimension": "possessive", "reverse": false, "text": "当我感觉到被忽视，会马上制造存在感。"},
    {"id": "P05", "dimension": "possessive", "reverse": false, "text": "我喜欢知道对方的动向以确保安全感。"},
    {"id": "P06", "dimension": "possessive", "reverse": true, "text": "我对于共享关系资源非常宽松。"},
    {"id": "P07", "dimension": "possessive", "reverse": false, "text": "我会设计\"仪式\"来确认对方的忠诚。"},
    {"id": "P08", "dimension": "possessive", "reverse": false, "text": "我喜欢掌握对方的社交圈层信息。"},
    {"id": "P09", "dimension": "possessive", "reverse": true, "text": "我认为各自保持私密空间很重要。"},
    {"id": "P10", "dimension": "possessive", "reverse": false, "text": "如果对方太自由，我会焦虑并介入。"},
    {"id": "P11", "dimension": "possessive", "reverse": false, "text": "我会通过小测试判断对方是否把我排第一。"},
    {"id": "P12", "dimension": "possessive", "reverse": true, "text": "我不太在乎对方跟谁走得更近。"},
    {"id": "P13", "dimension": "possessive", "reverse": false, "text": "我会用独特记号（昵称/暗语）来巩固我的专属权。"},
    {"id": "P14", "dimension": "possessive", "reverse": false, "text": "我天生会对关系建立边界和规矩。"},
    {"id": "P15", "dimension": "possessive", "reverse": false, "text": "我会下意识比较自己与\"潜在竞争者\"。"},
    {"id": "P16", "dimension": "possessive", "reverse": true, "text": "我对\"共享焦点\"持开放态度。"},

    {"id": "A01", "dimension": "aggression", "reverse": false, "text": "如果有人踩线，我会毫不犹豫地反击。"},
    {"id": "A02", "dimension": "aggression", "reverse": false, "text": "我会主动测试别人到底能接受我到什么程度。"},
    {"id": "A03", "dimension": "aggression", "reverse": true, "text": "我通常先忍耐很多次才会表达不满。"},
    {"id": "A04", "dimension": "aggression", "reverse": false, "text": "我不介意用\"强势\"提醒别人别越界。"},
    {"id": "A05", "dimension": "aggression", "reverse": false, "text": "我会针对性地设置规则来限制对方的行为。"},
    {"id": "A06", "dimension": "aggression", "reverse": true, "text": "即使别人冒犯我，我也倾向于息事宁人。"},
    {"id": "A07", "dimension": "aggression", "reverse": false, "text": "我会预设\"底线清单\"，别人触碰一次就会被标记。"},
    {"id": "A08", "dimension": "aggression", "reverse": false, "text": "当有人挑战我，我会用更高压的方式回应。"},
    {"id": "A09", "dimension": "aggression", "reverse": true, "text": "我更愿意通过沟通慢慢解决冲突。"},
    {"id": "A10", "dimension": "aggression", "reverse": false, "text": "我乐于通过\"试错\"找出别人的防线。"},
    {"id": "A11", "dimension": "aggression", "reverse": false, "text": "我会把别人的弱点变成我的盾牌或武器。"},
    {"id": "A12", "dimension": "aggression", "reverse": true, "text": "我宁可吃点亏，也不想把关系搞僵。"},
    {"id": "A13", "dimension": "aggression", "reverse": false, "text": "我会以\"规训\"来确保别人遵守约定。"},
    {"id": "A14", "dimension": "aggression", "reverse": false, "text": "我倾向用讽刺或暗示敲打对方。"},
    {"id": "A15", "dimension": "aggression", "reverse": false, "text": "如果我觉得受威胁，会立刻亮出更强硬的姿态。"},
    {"id": "A16", "dimension": "aggression", "reverse": true, "text": "我会尽量保持克制，不让冲突升级。"}
  ]
}
